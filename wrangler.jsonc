{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "plant-identification-online",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-17",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_NAME": "Plant Identification Online"
  }
}
